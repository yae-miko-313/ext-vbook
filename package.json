{
  "name": "vbook-tool",
  "version": "2.0.0",
  "description": "VBook 2-in-1 tool: personal extension repair/build plus community catalog aggregation",
  "author": "kychi",
  "main": "tools/cli/index.js",
  "bin": {
    "vbook": "./tools/cli/index.js"
  },

  "scripts": {
    "start": "node tools/cli/index.js",
    "ext:create": "node tools/cli/index.js ext --mode create",
    "ext:edit": "node tools/cli/index.js ext --mode edit --plugin extensions/novel/kychi_ntruyen/plugin.json --dry-run",
    "ext:create:dry": "node tools/cli/index.js ext --mode create --name DemoExt --source https://example.com --author kychi --dry-run",
    "build": "node tools/cli/index.js build --plugin extensions/novel/kychi_ntruyen",
    "build:catalog": "node tools/cli/index.js build-catalog",
    "sync:web-catalog": "node -e \"const {buildWebCatalog}=require('./tools/cli/build/sync-web-catalog');console.log(JSON.stringify(buildWebCatalog(process.cwd()), null, 2));\"",
    "full-sync": "npm run build:catalog && npm run sync:web-catalog"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5"
  }
}
