    "install:ext": "node tools/cli/index.js install --plugin extensions/ntruyen"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "dotenv": "^16.4.5",
    "commander": "^12.1.0",
    "string-argv": "^0.3.2"
  }
}
