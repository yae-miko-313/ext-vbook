{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/**/*.js": {
      "includeFiles": "web/remote-sources.json",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/web/$1"
    },
    {
      "source": "/",
      "destination": "/web/index.html"
    }
  ]
}
