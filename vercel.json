{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/vbook-ext",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/vbook-ext/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/vbook-ext/:path*",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "api/**/*.js": {
      "includeFiles": "web/remote-sources.json",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!web|api).*)",
      "destination": "/web/$1"
    }
  ]
}